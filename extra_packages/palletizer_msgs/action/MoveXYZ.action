# Absolute Cartesian setpoint in millimeters.
float32 x_mm
float32 y_mm
float32 z_mm

# Optional motion tuning. Values <= 0 use firmware defaults.
float32 speed_mm_s
float32 accel_mm_s2
float32 tolerance_mm
uint32 timeout_ms
---
bool success
string message
float32 final_x_mm
float32 final_y_mm
float32 final_z_mm
---
float32 current_x_mm
float32 current_y_mm
float32 current_z_mm
float32 error_x_mm
float32 error_y_mm
float32 error_z_mm
float32 progress
string state
