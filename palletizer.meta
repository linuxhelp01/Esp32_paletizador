{
  "names": {
    "rmw_microxrcedds": {
      "cmake-args": [
        "-DRMW_UXRCE_MAX_NODES=1",
        "-DRMW_UXRCE_MAX_PUBLISHERS=24",
        "-DRMW_UXRCE_MAX_SUBSCRIPTIONS=12",
        "-DRMW_UXRCE_MAX_SERVICES=32",
        "-DRMW_UXRCE_MAX_CLIENTS=8",
        "-DRMW_UXRCE_MAX_TOPICS=48",
        "-DRMW_UXRCE_MAX_HISTORY=16",
        "-DRMW_UXRCE_STREAM_HISTORY=16",
        "-DRMW_UXRCE_ENTITY_CREATION_DESTROY_TIMEOUT=15000",
        "-DRMW_UXRCE_PUBLISH_RELIABLE_TIMEOUT=2000",
        "-DRMW_UXRCE_TRANSPORT=custom"
      ]
    }
  }
}
