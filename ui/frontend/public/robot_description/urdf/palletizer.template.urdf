<?xml version="1.0"?>
<robot name="palletizer">
  <!--
    Plantilla cartesiana para React/Three.js.
    URDF usa metros. Las posiciones recibidas desde la UI/ESP32 estan en mm y
    deben convertirse con valor_m = valor_mm / 1000.
  -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/robot_description/meshes/stl/base.stl" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="x_axis_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="x_axis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.3" effort="100" velocity="1.0"/>
  </joint>

  <link name="x_axis_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/robot_description/meshes/stl/x_axis.stl" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="y_axis_joint" type="prismatic">
    <parent link="x_axis_link"/>
    <child link="y_axis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.3" effort="100" velocity="1.0"/>
  </joint>

  <link name="y_axis_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/robot_description/meshes/stl/y_axis.stl" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="z_axis_joint" type="prismatic">
    <parent link="y_axis_link"/>
    <child link="z_axis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.25" effort="100" velocity="1.0"/>
  </joint>

  <link name="z_axis_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/robot_description/meshes/stl/z_axis.stl" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="tool_fixed_joint" type="fixed">
    <parent link="z_axis_link"/>
    <child link="tool_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/robot_description/meshes/stl/tool.stl" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>
</robot>
